import './{{name}}.js';
import { html } from 'lit';
import { render } from 'vitest-browser-lit';
import { axeRun } from '../../internal/test/a11y.js';
import { {{className name}} } from './{{name}}.element';

describe('{{className name}}', () => {
  let element: {{className name}};

  beforeEach(async () => {
    element = render(html`<{{> tagnamePartial}}></{{> tagnamePartial}}>`)
      .container.querySelector('{{> tagnamePartial}}')!;
    await element.updateComplete;
  });

  it('is defined with its own instance', () => {
    expect(element).toBeInstanceOf({{className name}});
  });

  it('passes the a11y audit', async () => {
    expect(await axeRun(element)).toHaveNoViolations();
  });
});
