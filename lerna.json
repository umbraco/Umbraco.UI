{
  "$schema": "node_modules/@lerna-lite/cli/schemas/lerna-schema.json",
  "packages": ["."],
  "version": "2.0.0-alpha.1",
  "preid": "rc",
  "preDistTag": "prerelease",
  "exact": true,
  "noPush": true,
  "npmClient": "npm",
  "includeMergedTags": true,
  "conventionalCommits": true,
  "forcePublish": true,
  "ignoreChanges": ["**/*.story.ts", "**/*.test.ts", "**/CHANGELOG.md"]
}
